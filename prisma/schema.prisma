// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id             String   @id @default(uuid())
  
  // Mudanças aqui:
  name           String?  // <-- Virou Opcional (?)
  email          String?  // <-- Virou Opcional (?) e removemos o @unique por enquanto
  chatwootUrl    String   // <-- REMOVIDO @unique aqui
  
  apiAccessToken String   
  client         String?  // Headers adicionais para auth do Chatwoot
  uid            String?  // Headers adicionais para auth do Chatwoot
  accountId      Int      
  
  scheduledMessages ScheduledMessage[]
  followUps         FollowUp[]
  campaigns         Campaign[]
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([chatwootUrl, accountId]) // <-- ADICIONADO composite unique key
}

// Os outros models (ScheduledMessage e FollowUp) podem ficar iguais
model ScheduledMessage {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  
  conversationId Int?      
  contactId      Int?
  inboxId        Int?
  content        String   
  attachmentUrl  String?  
  scheduledAt    DateTime 
  status         String   @default("PENDING") 
  
  errorLog       String?  
  
  createdAt      DateTime @default(now())
  
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
}

model FollowUp {
  id             String   @id @default(uuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
  
  conversationId Int
  note           String   
  scheduledAt    DateTime
  status         String   @default("PENDING") 
  
  createdAt      DateTime @default(now())
}

model Campaign {
  id            String   @id @default(uuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  name          String
  status        String   @default("RUNNING") // RUNNING, PAUSED, COMPLETED, CANCELLED
  totalContacts Int
  sentCount     Int      @default(0)
  postSendLabel String?
  createdAt     DateTime @default(now())
  
  messages      ScheduledMessage[]
}